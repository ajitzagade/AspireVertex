# ── MongoDB (optional) ──
# Falls back to seed data when unset or unreachable.
# For production: use a MongoDB Atlas connection string.
# https://cloud.mongodb.com → Create free cluster → Get connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aspire

# ── Site URL ──
# Set to your Vercel deployment URL after first deploy
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
