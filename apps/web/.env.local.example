# MongoDB connection string (required for DB; app falls back to seed data without it)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# Public site URL (used for metadata/OG tags)
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Optional: internal API base URL (leave empty for same-origin Next.js API routes)
NEXT_PUBLIC_API_URL=

# Admin panel password — set this in Vercel Environment Variables
ADMIN_PASSWORD=change-me-to-something-strong

# Vercel Blob Storage — get from Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Email — Hostinger SMTP (for enquiry notifications to hello@aspirebuildcons.in)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@aspirebuildcons.in
SMTP_PASS=your-hostinger-email-password
